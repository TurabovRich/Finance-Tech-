APP_ENV=development
APP_NAME=Clarity API
APP_VERSION=0.1.0
DEBUG=true

DATABASE_URL=postgresql+asyncpg://clarity:clarity_dev@localhost:5432/clarity
# Optional: defaults to DATABASE_URL with `_test` appended if unset
# TEST_DATABASE_URL=postgresql+asyncpg://clarity:clarity_dev@localhost:5432/clarity_test

SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
